import numpy as np

class Config:
    def __init__(self):
        self.Nx = 450
        self.Ny = 340
        self.Lx = 45.0
        self.Ly = 34.0
        
        self.source_A_pos = np.array([-18.0, 3.0])
        self.source_B_pos = np.array([ -18.0, -3.0])
        
        self.amp_A = 1.0
        self.amp_B = 0.58
        self.phase_bias = np.pi / 2.15
        self.alpha = 7.0
        self.Ef = 0.45  # default Fermi level
        
        self.readout_points = [
            np.array([12.0, 4.0]), np.array([12.0, -4.0]),
            np.array([15.0, 2.0]), np.array([15.0, -2.0]),
            np.array([ 8.0, 6.0]), np.array([ 8.0, -6.0])
        ]
        
        self.freq_A = 5.0   # THz
        self.freq_B = 5.8   # THz
    
    def print_info(self):
        print("=== Multi-Stage Polariton Neuromorphic Simulator ===")
        print(f"Grid: {self.Nx}×{self.Ny} ({self.Lx}μm × {self.Ly}μm)")
        print(f"Fermi Level: {self.Ef} eV | Dual Freq: {self.freq_A}/{self.freq_B} THz")
        print(f"Readout points: {len(self.readout_points)}")
        print("==================================================\n")
